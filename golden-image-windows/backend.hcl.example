# backend.hcl.example
# ---------------------------------------------------------------------
# Template for the partial-backend override file consumed by
# `terraform init -backend-config=backend.hcl`.
#
# This file is GENERATED by bootstrap-sandbox.sh from the AWS account
# it discovers. Do not commit the rendered backend.hcl itself — it
# contains the resolved bucket name (which depends on the target
# account) and is therefore environment-specific.
#
# If you are bootstrapping manually instead of using the script, copy
# this file to backend.hcl and fill in the values for your environment.
# ---------------------------------------------------------------------

# S3 bucket that holds remote state. Created by bootstrap-sandbox.sh.
# Pattern: ${name_prefix}-tfstate-<account-id>-<region>
bucket = "REPLACE_WITH_STATE_BUCKET_NAME"

# Region of the state bucket. May be the same as var.aws_region or a
# dedicated governance region.
region = "us-east-1"

# Object key (path) inside the bucket. Defaults to
# golden-image-windows/terraform.tfstate.
key = "golden-image-windows/terraform.tfstate"
