        <mxCell id="legend_box" value="LEGEND — Coloured Flows&#10;&#10;■ BLUE   — OIDC / Authentication&#10;■ GREEN  — Terraform management (dashed)&#10;■ ORANGE — Build orchestration&#10;■ GOLD   — Logging &amp; KMS encryption&#10;■ PURPLE — State-change events (EventBridge)&#10;■ CYAN   — Lambda invocation&#10;■ MAGENTA — SSM / SNS updates&#10;■ CHOCOLATE — Cross-account distribution&#10;■ FOREST  — Downstream consumption&#10;&#10;━━ DASHED — Logical grouping / management&#10;━━ THIN   — Containment / attachment"
                style="text;html=1;align=left;verticalAlign=top;whiteSpace=wrap;rounded=1;fontSize=9;fontStyle=1;fillColor=#FFFFFF;strokeColor=#666666;dashed=1;spacingLeft=8;spacingTop=5;fontColor=#232F3E;"
                vertex="1" parent="1">
          <mxGeometry x="1900" y="95" width="460" height="180" as="geometry" />
        </mxCell>

        <!-- ================================================================== -->
        <!-- ZONE 1: EXTERNAL — GITHUB ACTIONS                                   -->
        <!-- ================================================================== -->
        <mxCell id="github_zone" value="ZONE 1 — EXTERNAL: GitHub Actions  (outside AWS account boundary)"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F4FF;strokeColor=#3B48CC;strokeWidth=2;dashed=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=5;fontSize=13;fontStyle=1;fontColor=#3B48CC;"
                vertex="1" parent="1">
          <mxGeometry x="40" y="95" width="1840" height="180" as="geometry" />
        </mxCell>

        <!-- Workflow 1: build -->
        <mxCell id="wf_build" value="Workflow 1: golden-image-build.yml&#10;on: push (component changes) | workflow_dispatch | weekly schedule&#10;env: golden-image-shared-services  |  runs-on: ubuntu-latest&#10;&#10;  ① actions/checkout@v4&#10;  ② aws-actions/configure-aws-credentials@v4&#10;       (OIDC → AWS_OIDC_ROLE_ARN secret)&#10;  ③ Lookup pipeline ARN by name&#10;  ④ aws imagebuilder start-image-pipeline-execution&#10;  ⑤ Poll get-image every 2 min (up to 90 min)&#10;       — AVAILABLE → success, FAILED → fail, else → wait&#10;  ⑥ On success: extract AMI ID, write to job summary"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;strokeWidth=2;fontSize=10;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=10;fontColor=#232F3E;"
                vertex="1" parent="1">
          <mxGeometry x="60" y="125" width="560" height="140" as="geometry" />
        </mxCell>

        <!-- Workflow 2: terraform -->
        <mxCell id="wf_tf" value="Workflow 2: golden-image-terraform.yml&#10;on: PR | push (tf/lambda changes) | workflow_dispatch&#10;&#10;  terraform-plan  (PRs + pushes)&#10;    ① checkout  ② OIDC  ③ setup-terraform@v3 (1.9.8)&#10;    ④ zip lambda deployment package&#10;    ⑤ terraform init / validate / fmt -check&#10;    ⑥ Generate terraform.tfvars from repo secrets&#10;    ⑦ terraform plan → upload as artifact&#10;    ⑧ Post plan summary to PR comment&#10;&#10;  terraform-apply  (pushes to main only)&#10;    ①–⑤ as above  ⑥ Download plan artifact&#10;    ⑦ terraform apply -auto-approve"
                style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#3B48CC;strokeWidth=2;fontSize=10;fontStyle=1;align=left;verticalAlign=middle;spacingLeft=10;fontColor=#232F3E;"
                vertex="1" parent="1">
          <mxGeometry x="640" y="125" width="560" height="140" as="geometry" />
        </mxCell>

        <!-- Repo info + secrets -->
        <mxCell id="gh_meta" value="Repository: SinghWorld/b-aws-tf-gha-ec2-imagebuilder&#10;Branch: main  |  Environment: golden-image-shared-services&#10;&#10;Repo Secrets (encrypted at rest, never in logs):&#10;  • AWS_OIDC_ROLE_ARN&#10;  • GOLDEN_IMAGE_SUBNET_ID&#10;  • GOLDEN_IMAGE_SG_IDS&#10;  • GOLDEN_IMAGE_KMS_KEY_ARN&#10;  • GOLDEN_IMAGE_DISTRIBUTION_ACCOUNTS&#10;  • GOLDEN_IMAGE_SNS_TOPIC_ARN"
