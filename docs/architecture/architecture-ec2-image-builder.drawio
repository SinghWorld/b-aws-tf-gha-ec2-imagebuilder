        <mxCell id="a_wf_pipeline" value="⑤  StartImagePipelineExecution"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#FF6600;strokeWidth=3;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#FF6600;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="wf_build" target="pipeline_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 6. Pipeline → Recipe (orange) -->
        <mxCell id="a_pipe_recipe" value="⑥  uses"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#ED7100;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#ED7100;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="pipeline_label" target="recipe_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 7. Pipeline → Infra Config (orange) -->
        <mxCell id="a_pipe_infra" value="⑦  runs in"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#ED7100;strokeWidth=2;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#ED7100;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="pipeline_label" target="infra_cfg_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 8. Infra Config → Build EC2 (orange, via SSM) -->
        <mxCell id="a_infra_ec2" value="⑧  launch &amp; orchestrate  (via SSM)"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#ED7100;strokeWidth=3;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#ED7100;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="infra_cfg_label" target="ec2_icon">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 9. EC2 → S3 (gold, stream logs) -->
        <mxCell id="a_ec2_s3" value="⑨  stream build &amp; test logs"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.3;entryDx=0;entryDy=0;strokeColor=#DAA520;strokeWidth=3;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#B8860B;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="ec2_label" target="s3_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 10. EC2 → KMS (gold, encrypts EBS) -->
        <mxCell id="a_ec2_kms" value="⑩  encrypts EBS root volume"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#B8860B;strokeWidth=3;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#B8860B;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="ec2_label" target="kms_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 11. Pipeline → EventBridge (purple, state change) -->
        <mxCell id="a_pipe_eb" value="⑪  Image State Change&#10;     (AVAILABLE / FAILED)"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#7B68EE;strokeWidth=3;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#5D4FB5;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="dist_cfg_label" target="eb_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 12. EventBridge → Lambda (cyan, invoke) -->
        <mxCell id="a_eb_lambda" value="⑫  invoke"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#00BFFF;strokeWidth=3;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#0099CC;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="eb_label" target="lambda_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 13. Lambda → SSM (magenta, PutParameter) -->
        <mxCell id="a_lambda_ssm" value="⑬  ssm:PutParameter  (latest AMI ID)"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#FF1493;strokeWidth=3;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#C2185B;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="lambda_label" target="ssm_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 14. Lambda → SNS (pink, publish) -->
        <mxCell id="a_lambda_sns" value="⑭  sns:Publish"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#FF69B4;strokeWidth=3;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#D81B60;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="lambda_label" target="sns_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 15. Pipeline → Distribution Config → Spokes (chocolate) -->
        <mxCell id="a_pipe_dist" value="⑮  golden-win2022-distribution&#10;      →  spoke accounts/regions"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#D2691E;strokeWidth=3;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#D2691E;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="dist_cfg_label" target="spoke1_box">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 16. AMI → Distribution (chocolate, encrypted copy) -->
        <mxCell id="a_ami_dist" value="⑯  encrypted AMI copy"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#D2691E;strokeWidth=3;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#D2691E;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="ami_box" target="spoke1_ami">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 17. SSM → Downstream Consumer (forest green) -->
        <mxCell id="a_ssm_consumer" value="⑰  data.aws_ssm_parameter.golden_ami"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#228B22;strokeWidth=3;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#1B5E20;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="ssm_label" target="consumer1_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 18. Spoke AMI → Downstream (forest green, launch) -->
        <mxCell id="a_spoke_consumer" value="⑱  launch EC2 from spoke AMI"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#228B22;strokeWidth=3;endArrow=block;endFill=1;fontSize=10;fontStyle=1;fontColor=#1B5E20;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="spoke4_ami" target="consumer1_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 19. State machine gate → EventBridge (purple) -->
        <mxCell id="a_state_eb" value="⑲  AVAILABLE → state change → EB"
                style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0.3;entryDx=0;entryDy=0;strokeColor=#7B68EE;strokeWidth=2;endArrow=open;endFill=0;dashed=1;dashPattern=4 4;fontSize=9;fontStyle=1;fontColor=#7B68EE;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="state_machine" target="eb_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- ================================================================== -->
        <!-- DASHED GROUPING ARROWS (containment / attachment)                  -->
        <!-- ================================================================== -->

        <!-- Subnet contains EC2 -->
        <mxCell id="a_subnet_ec2" value="lives in"
                style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#8C4FFF;strokeWidth=1;endArrow=open;endFill=0;dashed=1;dashPattern=4 4;fontSize=9;fontStyle=1;fontColor=#8C4FFF;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="subnet_label" target="ec2_icon">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- SG protects EC2 -->
        <mxCell id="a_sg_ec2" value="protected by"
                style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;strokeColor=#DD344C;strokeWidth=1;endArrow=open;endFill=0;dashed=1;dashPattern=4 4;fontSize=9;fontStyle=1;fontColor=#DD344C;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="sg_label" target="ec2_icon">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Instance Role attached to Profile (used by EC2) -->
        <mxCell id="a_role_profile" value="used by"
                style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;strokeColor=#DD344C;strokeWidth=1;endArrow=open;endFill=0;dashed=1;dashPattern=4 4;fontSize=9;fontStyle=1;fontColor=#DD344C;labelBackgroundColor=#FFFFFF;"
                edge="1" parent="1" source="ib_role_label" target="ec2_label">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
